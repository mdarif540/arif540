*&---------------------------------------------------------------------*
*& Report  ZAF_SMART_INVOICE_MULTIPLE
*&
*&---------------------------------------------------------------------*
*&
*&
*&---------------------------------------------------------------------*

REPORT  zaf_smart_invoice_multiple01.

DATA : it_final TYPE zaf_tt_vbrp_invoice,
       wa_final TYPE zaf_st_vbrp_invoice,
       it_kna1 TYPE STANDARD TABLE OF kna1,
       wa_kna1 TYPE kna1,
       it_temp TYPE zaf_tt_vbrp_invoice,
       lv_fm_name TYPE rs38l_fnam.

data : lv_qty_sum type fkimg,
       lv_price_sum type netwr_fp.

data : ls_control_parameters type SSFCTRLOP,
       ls_output_options type SSFCOMPOP.

DATA : lv_vbeln TYPE vbrk-vbeln.
SELECT-OPTIONS : s_vbeln FOR lv_vbeln.

START-OF-SELECTION.

  SELECT vbrk~vbeln
         vbrk~kunrg
         vbrp~posnr
         vbrp~fkimg
         vbrp~netwr
         vbrp~matnr
         vbrp~arktx
  FROM vbrk INNER JOIN vbrp
  ON vbrk~vbeln = vbrp~vbeln
  INTO TABLE it_final
  WHERE vbrk~vbeln IN s_vbeln.

  IF it_final IS NOT INITIAL.
    it_temp = it_final.
    SORT it_temp BY kunrg.
    DELETE ADJACENT DUPLICATES FROM it_temp COMPARING kunrg.

    SELECT *
    FROM kna1
    INTO TABLE it_kna1
     FOR ALL ENTRIES IN it_temp
     WHERE kunnr = it_temp-kunrg.
  ENDIF.

  CALL FUNCTION 'SSF_FUNCTION_MODULE_NAME'
    EXPORTING
      formname           = 'ZAF_SMART_INVOICE_MULIPLE01'
*     VARIANT            = ' '
*     DIRECT_CALL        = ' '
    IMPORTING
      fm_name            = lv_fm_name
    EXCEPTIONS
      no_form            = 1
      no_function_module = 2.



  REFRESH : it_temp.
  LOOP AT it_final INTO wa_final.

    APPEND wa_final TO it_temp.
    lv_qty_sum = lv_qty_sum + wa_final-fkimg.
    lv_price_sum = lv_price_sum + wa_final-netwr.

    READ TABLE it_kna1 INTO wa_kna1 WITH KEY kunnr = wa_final-kunrg.
    AT END OF vbeln.

ls_control_parameters-no_dialog = 'X'.
ls_control_parameters-preview = 'X'.
ls_output_options-TDDEST = 'LP01'.


        CALL FUNCTION lv_fm_name
          EXPORTING
*           ARCHIVE_INDEX              = ARCHIVE_INDEX
*           ARCHIVE_INDEX_TAB          = ARCHIVE_INDEX_TAB
*           ARCHIVE_PARAMETERS         = ARCHIVE_PARAMETERS
           CONTROL_PARAMETERS         = ls_CONTROL_PARAMETERS
*           MAIL_APPL_OBJ              = MAIL_APPL_OBJ
*           MAIL_RECIPIENT             = MAIL_RECIPIENT
*           MAIL_SENDER                = MAIL_SENDER
           OUTPUT_OPTIONS             = ls_OUTPUT_OPTIONS
           USER_SETTINGS              = ' '
            wa_kna1                    = wa_kna1
            lv_qty_sum                 = lv_qty_sum
            lv_price_sum               = lv_price_sum
*         IMPORTING
*           DOCUMENT_OUTPUT_INFO       = DOCUMENT_OUTPUT_INFO
*           JOB_OUTPUT_INFO            = JOB_OUTPUT_INFO
*           JOB_OUTPUT_OPTIONS         = JOB_OUTPUT_OPTIONS
          TABLES
            it_vbrp                    = it_temp
         EXCEPTIONS
           FORMATTING_ERROR           = 1
           INTERNAL_ERROR             = 2
           SEND_ERROR                 = 3
           USER_CANCELED              = 4
                  .


      REFRESH it_temp.
      CLEAR : lv_qty_sum , lv_price_sum.
    ENDAT.
  ENDLOOP.
