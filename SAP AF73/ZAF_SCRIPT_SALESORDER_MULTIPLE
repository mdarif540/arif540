REPORT  ZAF_SCRIPT_SALESORDER_MULTIPLE.

TYPES : BEGIN OF TY_VBAP,
        VBELN TYPE VBELN_VA,
        KUNNR TYPE KUNNR,
        POSNR TYPE POSNR_VA,
        MATNR TYPE MATNR,
        ARKTX TYPE ARKTX,
        KWMENG TYPE KWMENG,
        NETPR TYPE NETPR,
        END OF TY_VBAP.

DATA : IT_VBAP TYPE STANDARD TABLE OF TY_VBAP,
       WA_VBAP TYPE TY_VBAP,
       IT_KNA1 TYPE STANDARD TABLE OF KNA1,
       WA_KNA1 TYPE KNA1,
       IT_TEMP TYPE STANDARD TABLE OF TY_VBAP,
       LV_SUM TYPE NETPR,
       LV_WORDS TYPE SPELL.

DATA : LV_VBELN TYPE VBAK-VBELN.
SELECT-OPTIONS : S_VBELN FOR LV_VBELN.


SELECT VBAK~VBELN
       VBAK~KUNNR
       VBAP~POSNR
       VBAP~MATNR
       VBAP~ARKTX
       VBAP~KWMENG
       VBAP~NETPR
INTO TABLE IT_VBAP
FROM VBAK INNER JOIN VBAP
ON VBAK~VBELN = VBAP~VBELN
WHERE VBAK~VBELN IN S_VBELN.

IF IT_VBAP IS NOT INITIAL.
  IT_TEMP = IT_VBAP.
  SORT IT_TEMP BY KUNNR.
  DELETE ADJACENT DUPLICATES FROM IT_TEMP COMPARING KUNNR.

  SELECT *
   FROM KNA1
   INTO TABLE IT_KNA1
   FOR ALL ENTRIES IN IT_TEMP
   WHERE KUNNR = IT_TEMP-KUNNR.
ENDIF.

CALL FUNCTION 'OPEN_FORM'
 EXPORTING
*   APPLICATION                       = 'TX'
*   ARCHIVE_INDEX                     = ARCHIVE_INDEX
*   ARCHIVE_PARAMS                    = ARCHIVE_PARAMS
*   DEVICE                            = 'PRINTER'
*   DIALOG                            = 'X'
   FORM                              = 'ZAF_SCRIPTS10'
*   LANGUAGE                          = SY-LANGU
*   OPTIONS                           = OPTIONS
*   MAIL_SENDER                       = MAIL_SENDER
*   MAIL_RECIPIENT                    = MAIL_RECIPIENT
*   MAIL_APPL_OBJECT                  = MAIL_APPL_OBJECT
*   RAW_DATA_INTERFACE                = '*'
*   SPONUMIV                          = SPONUMIV
* IMPORTING
*   LANGUAGE                          = LANGUAGE
*   NEW_ARCHIVE_PARAMS                = NEW_ARCHIVE_PARAMS
*   RESULT                            = RESULT
 EXCEPTIONS
   CANCELED                          = 1
   DEVICE                            = 2
   FORM                              = 3
   OPTIONS                           = 4
   UNCLOSED                          = 5
   MAIL_OPTIONS                      = 6
   ARCHIVE_ERROR                     = 7
   INVALID_FAX_NUMBER                = 8
   MORE_PARAMS_NEEDED_IN_BATCH       = 9
   SPOOL_ERROR                       = 10
   CODEPAGE                          = 11
          .

LOOP AT IT_VBAP INTO WA_VBAP.
  READ TABLE IT_KNA1 INTO WA_KNA1 WITH KEY KUNNR = WA_VBAP-KUNNR.

  AT NEW VBELN.
    CALL FUNCTION 'START_FORM'
     EXPORTING
*         ARCHIVE_INDEX          = ARCHIVE_INDEX
       FORM                   = 'ZAF_SCRIPTS10'
*         LANGUAGE               = ' '
*         STARTPAGE              = ' '
*         PROGRAM                = ' '
*         MAIL_APPL_OBJECT       = MAIL_APPL_OBJECT
*       IMPORTING
*         LANGUAGE               = LANGUAGE
     EXCEPTIONS
       FORM                   = 1
       FORMAT                 = 2
       UNENDED                = 3
       UNOPENED               = 4
       UNUSED                 = 5
       SPOOL_ERROR            = 6
       CODEPAGE               = 7
              .
  ENDAT.

  CALL FUNCTION 'WRITE_FORM'
   EXPORTING
     ELEMENT                        = 'PRINT_ITEM '
*         FUNCTION                       = 'SET'
*         TYPE                           = 'BODY'
     WINDOW                         = 'MAIN'
*       IMPORTING
*         PENDING_LINES                  = PENDING_LINES
   EXCEPTIONS
     ELEMENT                        = 1
     FUNCTION                       = 2
     TYPE                           = 3
     UNOPENED                       = 4
     UNSTARTED                      = 5
     WINDOW                         = 6
     BAD_PAGEFORMAT_FOR_PRINT       = 7
     SPOOL_ERROR                    = 8
     CODEPAGE                       = 9
            .
  AT END OF VBELN.
    SUM.
    LV_SUM = WA_VBAP-NETPR.
    CALL FUNCTION 'SPELL_AMOUNT'
      EXPORTING
        AMOUNT    = LV_SUM
        CURRENCY  = 'INR'
*       FILLER    = ' '
*       LANGUAGE  = SY-LANGU
      IMPORTING
        IN_WORDS  = LV_WORDS
      EXCEPTIONS
        NOT_FOUND = 1
        TOO_LARGE = 2.



    CALL FUNCTION 'WRITE_FORM'
     EXPORTING
       ELEMENT                        = 'PRINT_TOTAL '
*         FUNCTION                       = 'SET'
*         TYPE                           = 'BODY'
       WINDOW                         = 'MAIN'
*       IMPORTING
*         PENDING_LINES                  = PENDING_LINES
     EXCEPTIONS
       ELEMENT                        = 1
       FUNCTION                       = 2
       TYPE                           = 3
       UNOPENED                       = 4
       UNSTARTED                      = 5
       WINDOW                         = 6
       BAD_PAGEFORMAT_FOR_PRINT       = 7
       SPOOL_ERROR                    = 8
       CODEPAGE                       = 9
              .
    CALL FUNCTION 'END_FORM'
*       IMPORTING
*         RESULT                         = RESULT
     EXCEPTIONS
       UNOPENED                       = 1
       BAD_PAGEFORMAT_FOR_PRINT       = 2
       SPOOL_ERROR                    = 3
       CODEPAGE                       = 4
              .
  ENDAT.


ENDLOOP.

CALL FUNCTION 'CLOSE_FORM'
*   IMPORTING
*     RESULT                         = RESULT
*     RDI_RESULT                     = RDI_RESULT
*   TABLES
*     OTFDATA                        = OTFDATA
 EXCEPTIONS
   UNOPENED                       = 1
   BAD_PAGEFORMAT_FOR_PRINT       = 2
   SEND_ERROR                     = 3
   SPOOL_ERROR                    = 4
   CODEPAGE                       = 5
          .
