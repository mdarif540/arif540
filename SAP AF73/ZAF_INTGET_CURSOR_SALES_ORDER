*&---------------------------------------------------------------------*
*& Report  ZAF_INTERACTIVE_SALES_ORDER
*&
*&---------------------------------------------------------------------*
*&
*&
*&---------------------------------------------------------------------*

REPORT  zaf_intget_cursor_sales_order.
TYPES : BEGIN OF ty_vbak,
        vbeln TYPE  vbeln_va,
        erdat TYPE erdat,
        erzet TYPE erzet,
        ernam TYPE  ernam,
        END OF ty_vbak.

TYPES : BEGIN OF ty_vbap,
        vbeln TYPE  vbeln_va,
        posnr TYPE  posnr_va,
        matnr TYPE  matnr,
        matwa TYPE  matwa,
        END OF ty_vbap.

DATA : it_vbak TYPE STANDARD TABLE OF ty_vbak,
       wa_vbak TYPE ty_vbak,
       it_vbap TYPE STANDARD TABLE OF ty_vbap,
       wa_vbap TYPE ty_vbap,
       it_makt TYPE STANDARD TABLE OF makt,
       wa_makt TYPE makt.

DATA : lv_vbeln TYPE vbap-vbeln.
SELECT-OPTIONS : s_vbeln FOR lv_vbeln.
SELECT vbeln
       erdat
       erzet
       ernam
FROM vbak
INTO TABLE it_vbak
WHERE vbeln IN s_vbeln.

LOOP AT it_vbak INTO wa_vbak.

  WRITE : / wa_vbak-vbeln COLOR 1 HOTSPOT ON,
            wa_vbak-erdat COLOR 2,
            wa_vbak-erzet COLOR 3,
            wa_vbak-ernam COLOR 4.

  HIDE : wa_vbak-vbeln.

ENDLOOP.

AT LINE-SELECTION.

  DATA : lv_fname TYPE char20,
         lv_fvalue TYPE vbeln_va.
  GET CURSOR FIELD lv_fname
             VALUE lv_fvalue.

  CASE sy-lsind.

    WHEN 1.
      IF lv_fname = 'WA_VBAK-VBELN'.
        SELECT vbeln
               posnr
               matnr
               matwa
       FROM vbap
       INTO TABLE it_vbap
       WHERE vbeln = wa_vbak-vbeln.

        IF it_vbap IS NOT INITIAL.
          LOOP AT it_vbap INTO wa_vbap.
            WRITE : / wa_vbap-vbeln,
                      wa_vbap-posnr,
                      wa_vbap-matnr COLOR 5 HOTSPOT ON,
                      wa_vbap-matwa.

            HIDE : wa_vbap-matnr.
          ENDLOOP.
        ENDIF.
      ENDIF.

    WHEN 2.

      IF lv_fname = 'WA_VBAP-MATNR'.
        SELECT *
         FROM makt
         INTO TABLE it_makt
         WHERE matnr = wa_vbap-matnr.

        IF it_makt IS NOT INITIAL.
          LOOP AT it_makt INTO wa_makt.
            WRITE : / wa_makt-matnr,
                      wa_makt-spras,
                      wa_makt-maktx.
          ENDLOOP.

        ENDIF.
      ENDIF.


  ENDCASE.
